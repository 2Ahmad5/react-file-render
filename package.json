{
  "name": "react-file-render",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react,react-dom,react-pdf",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch --external react,react-dom,react-pdf",
    "playground": "npm --prefix playground run dev",
    "playground:install": "npm --prefix playground install",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "lucide-react": "^1.14.0",
    "pdfjs-dist": "^4.8.69",
    "react-pdf": "^9.1.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "tsup": "^8.2.4",
    "typescript": "^5.6.3"
  }
}
