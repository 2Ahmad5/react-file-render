{
  "name": "react-file-render",
  "version": "0.1.0",
  "description": "React file renderer for PDF, DOCX, images, code, and folder sources",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2Ahmad5/react-file-render.git"
  },
  "bugs": {
    "url": "https://github.com/2Ahmad5/react-file-render/issues"
  },
  "homepage": "https://github.com/2Ahmad5/react-file-render#readme",
  "keywords": [
    "react",
    "file-renderer",
    "pdf",
    "docx",
    "image",
    "code"
  ],
  "scripts": {
    "build": "npm run build:css && tsup src/index.ts --format esm,cjs --dts --external react,react-dom,react-pdf",
    "build:css": "tailwindcss -c tailwind.config.js -i src/styles.css -o dist/styles.css --minify",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch --external react,react-dom,react-pdf",
    "playground": "npm --prefix playground run dev",
    "playground:install": "npm --prefix playground install",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "docx-preview": "^0.3.7",
    "lucide-react": "^1.14.0",
    "pdfjs-dist": "^4.8.69",
    "react-pdf": "^9.1.1",
    "shiki": "^4.0.2",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "tsup": "^8.2.4",
    "typescript": "^5.6.3"
  }
}
